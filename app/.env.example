# Copy this file to .env and fill in real values. .env is gitignored.
# These are read by the Electron main process (app/main.js) at startup.

# PostHog telemetry
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Google Calendar OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Outlook Calendar OAuth2 (PKCE public client — no secret)
OUTLOOK_CLIENT_ID=
